@model ShowtimeSelectionViewModel
@{
    ViewData["Title"] = "Funciones disponibles";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Funciones disponibles</h2>
        <p class="page-subtitle">Selecciona una función para iniciar la venta</p>
    </div>
    <div class="header-actions">
        <form method="get" class="filter-bar">
            <select name="eventId" class="filter-select" onchange="this.form.submit()">
                <option value="">Todos los eventos</option>
                @foreach (var ev in Model.Events)
                {
                    <option value="@ev.Id" selected="@(Model.EventFilter == ev.Id)">
                        @ev.Name
                    </option>
                }
            </select>
        </form>
    </div>
</div>

@if (!Model.Showtimes.Any())
{
    <div class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#DDDCDB" stroke-width="1.5">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <p>No hay funciones disponibles en este momento</p>
    </div>
}
else
{
    <div class="showtime-grid">
        @foreach (var show in Model.Showtimes)
        {
            var pct = show.TotalSeats > 0
                ? (int)((show.TotalSeats - show.AvailableSeats) * 100.0 / show.TotalSeats)
                : 0;
            var urgency = show.AvailableSeats < 10 ? "urgent" : show.AvailableSeats < 30 ? "low" : "";

            <div class="showtime-card @urgency">
                <div class="card-top">
                    <span class="event-tag">@show.Status</span>
                    <span class="event-price">$@show.BasePrice.ToString("N0")</span>
                </div>
                <h3 class="card-title">@show.EventName</h3>
                <div class="card-time">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    @show.StartTime.ToString("ddd dd MMM · HH:mm")
                </div>

                <div class="seat-progress">
                    <div class="progress-labels">
                        <span>Disponibles</span>
                        <span class="@urgency">@show.AvailableSeats / @show.TotalSeats</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width:@pct%"></div>
                    </div>
                </div>

                @if (show.AvailableSeats > 0)
                {
                    <a href="/Sales/Seats?showtimeId=@show.Id" class="btn-primary btn-card">
                        Seleccionar asientos
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                }
                else
                {
                    <button class="btn-disabled btn-card" disabled>Agotado</button>
                }
            </div>
        }
    </div>
}
